// core.prelude -- explicit-import scalar helpers (CPB Phase 1 / Stdlib Stage 1).
//
// This module is intentionally not a magic auto-prelude. Current compiler
// support proves normal module imports, zero-argument functions, I64 params,
// I64 returns, comparisons, and simple branching. Re-export/delegation between
// stdlib modules is not yet trusted, so these helpers are self-contained.

public function id_i64(x: I64) -> I64 begin
    return x;
end

public function zero_i64() -> I64 begin
    return 0;
end

public function one_i64() -> I64 begin
    return 1;
end

public function truthy_i64(x: I64) -> I64 begin
    if x == 0 begin
        return 0;
    end
    return 1;
end

public function fallback_i64(x: I64, fallback: I64) -> I64 begin
    if x == 0 begin
        return fallback;
    end
    return x;
end
