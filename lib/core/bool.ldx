// core.bool -- pure truthiness helpers (Stdlib Stage 0).
//
// No OS, no extern C, no malloc: bare-compatible (profile `bare`+). Stage 0
// represents boolean-style results as I64: 1 for true, 0 for false. Truthiness
// follows the same convention as core.assert.is_true: zero is false, nonzero is true.

public function truthy_i64(x: I64) -> I64 begin
    if x == 0 begin
        return 0;
    end
    return 1;
end

public function falsey_i64(x: I64) -> I64 begin
    if x == 0 begin
        return 1;
    end
    return 0;
end

public function not_i64(x: I64) -> I64 begin
    if x == 0 begin
        return 1;
    end
    return 0;
end

public function and_i64(a: I64, b: I64) -> I64 begin
    if a == 0 begin
        return 0;
    end
    if b == 0 begin
        return 0;
    end
    return 1;
end

public function or_i64(a: I64, b: I64) -> I64 begin
    if a != 0 begin
        return 1;
    end
    if b != 0 begin
        return 1;
    end
    return 0;
end

public function xor_i64(a: I64, b: I64) -> I64 begin
    let left: I64 = truthy_i64(a);
    let right: I64 = truthy_i64(b);
    if left == right begin
        return 0;
    end
    return 1;
end
