// =========================================================================
// Threading Foundation: Actor & Channel
//
// Actor  = Unit concurrency (1 OS Thread)
// Channel  = SPSC channel dengan type-level capability
//
// Topology divalidasi pada masa kompilasi — tiada race condition
// yang boleh dikesan pada masa kompilasi akan lulus.
// =========================================================================

// ─── Actor ───
// Unit concurrency — setiap Actor berjalan pada 1 OS Thread.
// Topologi komunikasi (Channel) didefinisikan pada masa kompilasi.
//
// Contoh:
//   actor SensorSuhu {
//       let channel_data: Channel<SensorSuhu, ActorEnjin, DataSuhu>
//       channel_data.send(Ok(DataSuhu{ nilai: 25.5 }))
//   }

// ─── Channel<T, U, V> ───
// Channel SPSC (Single Producer Single Consumer) dengan type-level capability.
// 
// T = Actor pengsend (sender)
// U = Actor penerima (receiver)
// V = Jenis mesej (message type)
//
// Contoh:
//   let channel_data: Channel<SensorSuhu, ActorEnjin, DataSuhu>(256, Blok)
//
// Policy:
//   Blok       — Pengsend join sehingga ruang ada
//   GugurLama  — Mesej lama digugur jika buffer full
//   Parkir     — Pengsend "parkir" — OS scheduler tukar thread

// ─── spawn ───
// Cipta OS Thread untuk Actor.
// Sintaks: spawn ActorNama()
//
// Contoh:
//   spawn SensorSuhu()
//   spawn ActorEnjin()

// ─── join ───
// Join Actor selesai (pthread_join).
// Sintaks: join ActorNama
//
// Contoh:
//   join SensorSuhu
//   join ActorEnjin

// ─── Topology Validation ───
// Compiler akan semak:
//   1. Semua Actor yang dirujuk dalam Channel mesti wujud
//   2. Tiada Channel ke Actor yang tidak diisytiharkan
//   3. Jenis mesej dalam send/recv mesti sepadan
//   4. Actor tidak boleh berkomunikasi dengan dirinya sendiri

// ─── Zero-Copy Ownership ───
// Apabila send() dipanggil, ownership data DIPINDAHKAN (moved).
// Data tidak boleh digunakan selepas send() — RAII safety.
//
// Contoh:
//   let data = DataSuhu{ nilai: 25.5 }
//   channel_data.send(data)
//   // data tidak boleh digunakan di sini — UseAfterMove error

// ─── Memory Ordering ───
// Semua operasi Channel menggunakan Acquire/Release semantics:
//   send()  → Release (data tersedia kepada penerima)
//   recv()  → Acquire (data diperoleh daripada pengsend)
//
// Ini memastikan tiada data race tanpa penggunaan Mutex.
