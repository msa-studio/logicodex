// =========================================================================
// Logicodex v1.30.1-alpha — Threading Foundation: Kotak & Pintu
//
// Kotak  = Unit concurrency (1 OS Thread)
// Pintu  = SPSC channel dengan type-level capability
//
// Topology divalidasi pada masa kompilasi — tiada race condition
// yang boleh dikesan pada masa kompilasi akan lulus.
// =========================================================================

// ─── Kotak ───
// Unit concurrency — setiap Kotak berjalan pada 1 OS Thread.
// Topologi komunikasi (Pintu) didefinisikan pada masa kompilasi.
//
// Contoh:
//   kotak SensorSuhu {
//       let pintu_data: Pintu<SensorSuhu, KotakEnjin, DataSuhu>
//       pintu_data.hantar(Ok(DataSuhu{ nilai: 25.5 }))
//   }

// ─── Pintu<T, U, V> ───
// Channel SPSC (Single Producer Single Consumer) dengan type-level capability.
// 
// T = Kotak penghantar (sender)
// U = Kotak penerima (receiver)
// V = Jenis mesej (message type)
//
// Contoh:
//   let pintu_data: Pintu<SensorSuhu, KotakEnjin, DataSuhu>(256, Blok)
//
// Policy:
//   Blok       — Penghantar tunggu sehingga ruang ada
//   GugurLama  — Mesej lama digugur jika penimbal penuh
//   Parkir     — Penghantar "parkir" — OS scheduler tukar thread

// ─── lahirkan ───
// Cipta OS Thread untuk Kotak.
// Sintaks: lahirkan KotakNama()
//
// Contoh:
//   lahirkan SensorSuhu()
//   lahirkan KotakEnjin()

// ─── tunggu ───
// Tunggu Kotak selesai (pthread_join).
// Sintaks: tunggu KotakNama
//
// Contoh:
//   tunggu SensorSuhu
//   tunggu KotakEnjin

// ─── Topology Validation ───
// Compiler akan semak:
//   1. Semua Kotak yang dirujuk dalam Pintu mesti wujud
//   2. Tiada Pintu ke Kotak yang tidak diisytiharkan
//   3. Jenis mesej dalam hantar/terima mesti sepadan
//   4. Kotak tidak boleh berkomunikasi dengan dirinya sendiri

// ─── Zero-Copy Ownership ───
// Apabila hantar() dipanggil, ownership data DIPINDAHKAN (moved).
// Data tidak boleh digunakan selepas hantar() — RAII safety.
//
// Contoh:
//   let data = DataSuhu{ nilai: 25.5 }
//   pintu_data.hantar(data)
//   // data tidak boleh digunakan di sini — UseAfterMove error

// ─── Memory Ordering ───
// Semua operasi Pintu menggunakan Acquire/Release semantics:
//   hantar()  → Release (data tersedia kepada penerima)
//   terima()  → Acquire (data diperoleh daripada penghantar)
//
// Ini memastikan tiada data race tanpa penggunaan Mutex.
