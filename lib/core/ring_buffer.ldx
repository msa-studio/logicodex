// =========================================================================
// SPSC Ring Buffer (with Backpressure)
//
// Single Producer Single Consumer ring buffer with memory ordering.
// Core data structure for Channel communication.
//
// Memory Ordering:
//   Producer (send): write data → Release write to tail
//   Consumer (recv): Acquire read from head → read data
//
// Guarantees:
//   - Consumer sees all writes from Producer
//   - No data races without Mutex
//   - Zero-copy ownership transfer
//   - Backpressure: try_send returns Result (full = Err)
// =========================================================================

struct RingBuffer<T> {
    buffer: *mut T,      // Pointer ke array data
    capacity: i32,         // Saiz buffer (mesti power-of-2)
    head: *mut i32,      // Consumer read position (Atomic)
    tail: *mut i32,        // Producer write position (Atomic)
}

// ─── ring_new ───
// Cipta RingBuffer baru dengan capacity tertentu.
// Kapasiti mesti power-of-2 untuk optimization bitwise.
function ring_new<T>(capacity: i32) -> RingBuffer<T> {
    // Pastikan capacity adalah power-of-2
    let mut k = capacity
    if (k & (k - 1) != 0) {
        // Round up kepada power-of-2 seterusnya
        k = 1
        while (k < capacity) {
            k = k << 1
        }
    }
    
    // Allocate memory (static allocation untuk bare-metal)
    let buffer = alloc(k * size_of::<T>())
    let head = alloc(4) as *mut i32   // 4 bytes untuk i32
    let tail = alloc(4) as *mut i32
    
    // Initialize atomics kepada 0
    *head = 0
    *tail = 0
    
    RingBuffer {
        buffer: buffer,
        capacity: k,
        head: head,
        tail: tail
    }
}

// ─── ring_send ───
// Send nilai ke RingBuffer (Producer — Release semantics).
// Return true jika berjaya, false jika buffer full.
//
// Memory ordering: Release pada tail update
// Ini memastikan Consumer nampak data sebelum nampak tail update.
function ring_send<T>(ring: *mut RingBuffer<T>, nilai: T) -> bool {
    let tail_semula = *ring.tail          // Read tail (plain — hanya Producer tulis)
    let head_semasa = *ring.head      // Read head (Acquire — Consumer mungkin update)
    
    // Semak jika buffer full
    let size = tail_semula - head_semasa
    if (size >= ring.capacity) {
        return false  // Penimbal full
    }
    
    // Tulis data ke posisi tail
    let indeks = tail_semula & (ring.capacity - 1)  // Modulo dengan bitwise AND
    ring.buffer[indeks] = nilai
    
    // Update tail dengan Release semantics
    // Ini adalah "memory barrier" — semua writes sebelum ini
    // akan nampak kepada threads lain selepas mereka baca tail.
    *ring.tail = tail_semula + 1
    
    true
}

// ─── ring_recv ───
// Recv nilai dari RingBuffer (Consumer — Acquire semantics).
// Return Some(nilai) jika ada data, None jika empty.
//
// Memory ordering: Acquire pada head read
// Ini memastikan Producer writes nampak selepas head read.
function ring_recv<T>(ring: *mut RingBuffer<T>) -> Option<T> {
    let head_semula = *ring.head      // Read head (plain — hanya Consumer tulis)
    let tail_semasa = *ring.tail          // Read tail (Acquire — Producer mungkin update)
    
    // Semak jika buffer empty
    if (head_semula == tail_semasa) {
        return None  // Penimbal empty
    }
    
    // Baca data dari posisi head
    let indeks = head_semula & (ring.capacity - 1)
    let nilai = ring.buffer[indeks]
    
    // Update head dengan Release semantics
    // Ini memberitahu Producer bahawa slot ini kini empty.
    *ring.head = head_semula + 1
    
    Some(nilai)
}

// ─── ring_empty ───
// Check jika RingBuffer empty.
function ring_empty<T>(ring: *RingBuffer<T>) -> bool {
    *ring.head == *ring.tail
}

// ─── ring_full ───
// Check jika RingBuffer full.
function ring_full<T>(ring: *RingBuffer<T>) -> bool {
    (*ring.tail - *ring.head) >= ring.capacity
}

// ─── ring_size ───
// Bilangan elemen dalam RingBuffer.
function ring_size<T>(ring: *RingBuffer<T>) -> i32 {
    *ring.tail - *ring.head
}

// ─── ring_try_send ───
// Phase 3: Non-blocking send with backpressure.
// Returns Ok(true) on success, Err(ChannelFull) if buffer full.
function ring_try_send<T>(ring: *mut RingBuffer<T>, nilai: T) -> Result<bool, IoError> {
    if (ring_full(ring)) {
        return Err(ChannelFull)
    }
    let berjaya = ring_send(ring, nilai)
    if (berjaya) {
        Ok(true)
    } else {
        Err(ChannelFull)
    }
}

// ─── ring_try_recv ───
// Phase 3: Non-blocking recv.
// Returns Some(nilai) if data available, None if buffer empty.
function ring_try_recv<T>(ring: *mut RingBuffer<T>) -> Option<T> {
    if (ring_empty(ring)) {
        return None
    }
    ring_recv(ring)
}

// ─── ring_timeout_recv ───
// Phase 3: Blocking recv with timeout.
// Returns Ok(nilai) on success, Err(Timeout) if timeout reached.
function ring_timeout_recv<T>(ring: *mut RingBuffer<T>, timeout_ms: i32) -> Result<T, RecvTimeout> {
    let start = get_time_ms()
    while (get_time_ms() - start < timeout_ms) {
        let result = ring_try_recv(ring)
        if (result.is_some()) {
            return Ok(result.unwrap())
        }
        // Spin-wait (or yield in cooperative scheduler)
        yield()
    }
    Err(RecvTimeout { channel: "ring", timeout_ms: timeout_ms })
}
