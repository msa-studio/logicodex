// core.result -- typed Result<I64, I64> helpers (CPB Phase 1 / Stdlib Stage 1).
//
// This module replaces the older aspirational generic Result<T, E> sketch with
// a small contract-backed API proven by the current compiler foundation:
// - Result<I64, I64>
// - Ok(v) / Err(e) constructors
// - match Ok(v) / Err(e) destructuring
//
// Generic Result<T, E>, map/and_then, expect/panic, String errors, IO errors,
// and higher-order function payloads are intentionally deferred until the
// compiler proves those semantics end to end.

public function unwrap_or_i64(x: Result<I64, I64>, fallback: I64) -> I64 begin
    match x begin
        Ok(v) => begin
            return v;
        end,
        Err(e) => begin
            return fallback;
        end
    end
end

public function unwrap_err_or_i64(x: Result<I64, I64>, fallback: I64) -> I64 begin
    match x begin
        Ok(v) => begin
            return fallback;
        end,
        Err(e) => begin
            return e;
        end
    end
end

public function is_ok_i64(x: Result<I64, I64>) -> I64 begin
    match x begin
        Ok(v) => begin
            return 1;
        end,
        Err(e) => begin
            return 0;
        end
    end
end

public function is_err_i64(x: Result<I64, I64>) -> I64 begin
    match x begin
        Ok(v) => begin
            return 0;
        end,
        Err(e) => begin
            return 1;
        end
    end
end
