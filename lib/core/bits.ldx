// core.bits -- pure integer bit-mask helpers (Stdlib Stage 0).
//
// No OS, no extern C, no malloc: bare-compatible (profile `bare`+). English
// canonical names. Stage 0 keeps the surface small and uses only stable binary
// bitwise operators: &, |, and ^. Shift and bit-not helpers can be added later
// after their public semantics are documented.

public function bit_and_i64(a: I64, b: I64) -> I64 begin
    return a & b;
end

public function bit_or_i64(a: I64, b: I64) -> I64 begin
    return a | b;
end

public function bit_xor_i64(a: I64, b: I64) -> I64 begin
    return a ^ b;
end

public function has_flag_i64(value: I64, flag: I64) -> I64 begin
    let present: I64 = value & flag;
    if present == 0 begin
        return 0;
    end
    return 1;
end

public function set_flag_i64(value: I64, flag: I64) -> I64 begin
    return value | flag;
end

public function toggle_flag_i64(value: I64, flag: I64) -> I64 begin
    return value ^ flag;
end

public function clear_flag_i64(value: I64, flag: I64) -> I64 begin
    let present: I64 = value & flag;
    return value - present;
end
