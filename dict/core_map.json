{
  "version": "1.21-alpha",
  "language": "Logicodex",
  "description": "Canonical v1.21-alpha dictionary mapping novice pseudocode and expert shorthand lexemes into unified compiler token identities.",
  "tokens": [
    { "identity": "START", "lexemes": ["MULA", "BEGIN", "{"], "description": "Begin a program or block." },
    { "identity": "END", "lexemes": ["TAMAT", "END", "}"], "description": "End a program or block." },
    { "identity": "LET", "lexemes": ["BINA", "let"], "description": "Create an immutable typed or inferred binding." },
    { "identity": "IF", "lexemes": ["JIKA", "if"], "description": "Begin a conditional branch." },
    { "identity": "THEN", "lexemes": ["MAKA", "then"], "description": "Separate a novice condition from its branch body." },
    { "identity": "ELSE", "lexemes": ["JIKALAU_TIDAK", "else"], "description": "Begin the alternative branch." },
    { "identity": "PRINT", "lexemes": ["PAPAR", "print"], "description": "Print an integer, boolean, string length, or address-shaped value." },
    { "identity": "HW", "lexemes": ["KAWASAN_PERKAKAS", "hw"], "description": "Declare a provenance-bearing hardware memory region." },
    { "identity": "ADDR", "lexemes": ["ALAMAT", "addr"], "description": "Introduce an address literal that requires provenance under strict targets." },
    { "identity": "USE", "lexemes": ["GUNA", "use"], "description": "Import a standard or platform module contract." },
    { "identity": "FN", "lexemes": ["FUNGSI", "fn"], "description": "Begin a function definition." },
    { "identity": "RETURN", "lexemes": ["PULANG", "return"], "description": "Return a value from a function body." },
    { "identity": "TRUE", "lexemes": ["BENAR", "true"], "description": "Boolean true literal." },
    { "identity": "FALSE", "lexemes": ["SALAH", "PALSU", "false"], "description": "Boolean false literal." },
    { "identity": "I32", "lexemes": ["I32"], "description": "Signed 32-bit integer type." },
    { "identity": "I64", "lexemes": ["I64"], "description": "Signed 64-bit integer type." },
    { "identity": "U16", "lexemes": ["U16"], "description": "Unsigned 16-bit integer type." },
    { "identity": "U32", "lexemes": ["U32"], "description": "Unsigned 32-bit integer type." },
    { "identity": "F64", "lexemes": ["F64"], "description": "64-bit floating-point type marker." },
    { "identity": "BOOL", "lexemes": ["Bool", "BOOL"], "description": "Boolean type marker." },
    { "identity": "PTR", "lexemes": ["PTR", "ptr"], "description": "Pointer type constructor." },
    { "identity": "ASSIGN", "lexemes": ["="], "description": "Assignment delimiter in a binding or declaration." },
    { "identity": "PLUS", "lexemes": ["+"], "description": "Numeric addition operator." },
    { "identity": "MINUS", "lexemes": ["-"], "description": "Numeric subtraction operator." },
    { "identity": "STAR", "lexemes": ["*"], "description": "Numeric multiplication operator." },
    { "identity": "SLASH", "lexemes": ["/"], "description": "Numeric division operator; constant zero is rejected statically." },
    { "identity": "GREATER", "lexemes": [">"] , "description": "Greater-than comparison." },
    { "identity": "GREATER_EQUAL", "lexemes": [">="], "description": "Greater-than-or-equal comparison." },
    { "identity": "LESS", "lexemes": ["<"], "description": "Less-than comparison." },
    { "identity": "LESS_EQUAL", "lexemes": ["<="], "description": "Less-than-or-equal comparison." },
    { "identity": "EQUAL_EQUAL", "lexemes": ["=="], "description": "Equality comparison." },
    { "identity": "BANG_EQUAL", "lexemes": ["!="], "description": "Inequality comparison." },
    { "identity": "LEFT_PAREN", "lexemes": ["("], "description": "Open grouped expression or parameter list." },
    { "identity": "RIGHT_PAREN", "lexemes": [")"], "description": "Close grouped expression or parameter list." },
    { "identity": "COLON", "lexemes": [":"], "description": "Type annotation delimiter." },
    { "identity": "SEMICOLON", "lexemes": [";"], "description": "Statement separator." },
    { "identity": "COMMA", "lexemes": [","], "description": "Parameter separator." },
    { "identity": "ARROW", "lexemes": ["->"], "description": "Function return type delimiter." }
  ]
}
