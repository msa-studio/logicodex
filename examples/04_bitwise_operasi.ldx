// =========================================================================
// Project: Logicodex Language Engine
// Compatibility: v1.21-alpha check + v1.30.0-alpha dormant subsystem check
// Purpose: Bitwise and shift operations for reflex-engine signal masking.
// =========================================================================

{
    let sensor: U32 = 42;
    let mask: U32 = 15;
    let low_bits: U32 = sensor & mask;
    let shifted: U32 = sensor >> 1;
    let routed: U32 = (low_bits | shifted) << 1;
    print routed;
}
