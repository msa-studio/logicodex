# --- Malay ---
FUNGSI fibonacci(n: I32) -> I32 MULA
    JIKA n <= 1 MAKA
        PULANG n
    MELAINKAN
        PULANG fibonacci(n - 1) + fibonacci(n - 2)
TAMAT

FUNGSI main() -> I32 MULA
    # Variable declarations
    BINA hitung: I32 = 0
    BINA jumlah: I32 = 0

    # While loop with counter
    SELAGI hitung < 10 MULA
        hitung = hitung + 1

        # Skip even numbers
        JIKA hitung bit_dan 1 == 0 MAKA
            TERUS

        # Accumulate
        jumlah = jumlah + hitung
    TAMAT

    # Fibonacci calculation
    BINA fib6: I32 = fibonacci(6)

    # Result/match
    BINA keputusan: RESULT = OK fib6
    BINA akhir: I32 = MATCH keputusan MULA
        OK v => v + jumlah
        ERR _ => 0
        _ => 99
    TAMAT

    PAPAR akhir
    PULANG 0
TAMAT

# --- Expert Canonical ---
fn fibonacci(n: i32) -> i32 {
    if n <= 1 then
        return n
    else
        return fibonacci(n - 1) + fibonacci(n - 2)
}

fn main() -> i32 {
    let count: i32 = 0
    let sum: i32 = 0

    while count < 10 {
        count = count + 1

        if count & 1 == 0 then
            continue

        sum = sum + count
    }

    let fib6: i32 = fibonacci(6)

    let decision: Result = Ok fib6
    let final_val: i32 = match decision {
        Ok v => v + sum
        Err _ => 0
        _ => 99
    }

    print final_val
    return 0
}

# --- Expected Output ---
# fibonacci(6) = 8
# sum of odd 1..10 = 1+3+5+7+9 = 25
# final = 8 + 25 = 33
# Should print: 33
