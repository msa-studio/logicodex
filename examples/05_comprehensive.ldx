# Tahap 5 — Komprehensif: fungsi + struct + gelung + jika
BENTUK Kira MULA
    nilai: I32;
TAMAT
FUNGSI dua_kali(n: I32) -> I32 MULA
    PULANG n * 2;
TAMAT
BINA jumlah: I32 = 0;
BINA i: I32 = 1;
SELAGI i <= 5 MULA
    jumlah = jumlah + dua_kali(i);
    i = i + 1;
TAMAT
JIKA jumlah > 20 MULA
    PAPAR jumlah;
TAMAT
MELAINKAN MULA
    PAPAR 0;
TAMAT
