// Level 3: Nested loops with accumulator + function
// Tests: SELAGI bersarang + fn + return + expression calls
MULA
BINA jadual: I64 = 0

SELAGI jadual < 5 MAKA
MULA
    BINA baris: I64 = 0
    SELAGI baris < 4 MAKA
    MULA
        BINA hasil: I64 = jadual * baris
        PAPAR hasil
        BINA baris = baris + 1
    TAMAT
    BINA jadual = jadual + 1
TAMAT

fn darab(a: I64, b: I64) -> I64 MULA
    BINA keputusan: I64 = a * b
    PULANG keputusan
TAMAT

fn tambah(a: I64, b: I64) -> I64 MULA
    BINA keputusan: I64 = a + b
    PULANG keputusan
TAMAT

BINA x: I64 = 5
BINA y: I64 = 3
BINA z: I64 = darab(x, y)
BINA w: I64 = tambah(z, 2)
PAPAR w

SELAGI x > 0 MAKA
MULA
    BINA y: I64 = 0
    SELAGI y < x MAKA
    MULA
        BINA hasil: I64 = darab(x, y)
        PAPAR hasil
        BINA y = y + 1
    TAMAT
    BINA x = x - 1
TAMAT
TAMAT
