// Logicodex v1.21 — Boolean logic (beginner/Malay syntax)
MULA
BINA signal: I64 = 18
BINA threshold: I64 = 12
BINA armed: Bool = benar
BINA fallback: Bool = palsu

JIKA signal > threshold DAN armed MAKA
MULA
    PAPAR 1
TAMAT
JIKALAU_TIDAK
MULA
    JIKA fallback ATAU signal == threshold MAKA
    MULA
        PAPAR 2
    TAMAT
    JIKALAU_TIDAK
    MULA
        PAPAR 0
    TAMAT
TAMAT
TAMAT
