# ============================================================
# LEVEL 4C: HARDWARE UNSAFE ZONE
# Purpose: Test ZON_PERKAKASAN/hw_unsafe for embedded bare-metal
# Grammar: ZON_PERKAKASAN MULA ... TAMAT or hw_unsafe { ... }
# DEBUG STRATEGY:
#   If hw_unsafe rejected: parser intentionally rejects it
#   Check: hw_unsafe may require --embedded or --kernel policy flag
#   The zone allows raw memory access and unsafe operations
#   Pointer provenance tracking is enforced
# ============================================================

# --- Malay ---
ZON_PERKAKASAN MULA
    BINA alamat: PTR = ALAMAT 0x1000
    PAPAR 1
TAMAT

# --- Expert Canonical ---
hw_unsafe {
    LET addr: PTR = addr 0x1000
    PRINT 1
}

# --- Known Limitations ---
# Hardware zones may be rejected in standard compilation mode
# May require: --embedded or --kernel policy flags
# addr literal requires valid provenance
