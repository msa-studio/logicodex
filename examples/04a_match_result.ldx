# ============================================================
# LEVEL 4A: MATCH ON RESULT TYPE
# Purpose: Test MATCH expression with Result<T,E> patterns
# Grammar: MATCH expr { Ok(v) => ..., Err(e) => ..., _ => ... }
# DEBUG STRATEGY:
#   If MATCH fails: parse_match() not implemented or pattern mismatch
#   Only Ok(v), Err(e), and _ patterns are supported
#   Literal patterns (5, "text") and tuple patterns are NOT parsed
#   The Result type must be declared before use
# ============================================================

# --- Malay ---
BINA hasil: RESULT = OK 42

BINA nilai: I32 = MATCH hasil MULA
    OK v => v
    ERR e => 0
    _ => 99
TAMAT

PAPAR nilai

# --- Expert Canonical ---
LET result: Result = OK 42

LET value: I32 = MATCH result {
    OK v => v
    ERR e => 0
    _ => 99
}

PRINT value

# --- Known Limitations ---
# Match only supports: Ok(v), Err(e), _ (wildcard)
# No literal patterns, no tuple patterns, no guards
# The => arrow is required for each arm
