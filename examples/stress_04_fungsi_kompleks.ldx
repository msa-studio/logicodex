// Level 4: Multiple functions with mutual logic
// Tests: fn + return + function calls + nested conditionals
MULA
fn max(a: I64, b: I64) -> I64 MULA
    JIKA a > b MAKA
    MULA
        PULANG a
    TAMAT
    PULANG b
TAMAT

fn min(a: I64, b: I64) -> I64 MULA
    JIKA a < b MAKA
    MULA
        PULANG a
    TAMAT
    PULANG b
TAMAT

fn clamp(x: I64, bawah: I64, atas: I64) -> I64 MULA
    JIKA x < bawah MAKA
    MULA
        PULANG bawah
    TAMAT
    JIKA x > atas MAKA
    MULA
        PULANG atas
    TAMAT
    PULANG x
TAMAT

fn sign(x: I64) -> I64 MULA
    JIKA x > 0 MAKA
    MULA
        PULANG 1
    TAMAT
    JIKA x < 0 MAKA
    MULA
        PULANG -1
    TAMAT
    PULANG 0
TAMAT

fn abs(x: I64) -> I64 MULA
    JIKA x < 0 MAKA
    MULA
        PULANG -x
    TAMAT
    PULANG x
TAMAT

fn limit(a: I64, b: I64, c: I64) -> I64 MULA
    BINA terendah: I64 = min(a, b)
    BINA tertinggi: I64 = max(a, b)
    BINA terhad: I64 = clamp(c, terendah, tertinggi)
    PULANG terhad
TAMAT

BINA nilai1: I64 = 10
BINA nilai2: I64 = 25
BINA nilai3: I64 = 7
BINA keputusan: I64 = limit(nilai1, nilai2, nilai3)
PAPAR keputusan

BINA positif: I64 = sign(keputusan)
PAPAR positif

BINA am: I64 = abs(-42)
PAPAR am
TAMAT
