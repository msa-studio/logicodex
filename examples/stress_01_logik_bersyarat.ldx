// Level 1: Nested conditionals with logical operators
// Tests: JIKA/MAKA/MELAINKAN + DAN/ATAU + comparison operators
MULA
BINA nilai: I64 = 85
BINA lulus: Bool = palsu
BINA gred = "F"

JIKA nilai >= 80 DAN lulus MAKA
MULA
    BINA gred = "A"
    PAPAR gred
TAMAT
MELAINKAN
MULA
    JIKA nilai >= 60 MAKA
    MULA
        JIKA nilai >= 70 MAKA
        MULA
            BINA gred = "B"
            PAPAR gred
        TAMAT
        MELAINKAN
        MULA
            BINA gred = "C"
            PAPAR gred
        TAMAT
    TAMAT
    MELAINKAN
    MULA
        JIKA nilai >= 50 MAKA
        MULA
            BINA gred = "D"
            PAPAR gred
        TAMAT
        MELAINKAN
        MULA
            BINA gred = "E"
            PAPAR gred
        TAMAT
    TAMAT
TAMAT

JIKA lupa ATAU gred == "F" MAKA
MULA
    PAPAR 0
TAMAT
TAMAT
