// Level 2: Loops with conditional break/continue
// Tests: SELAGI/ULANG + HENTI/LANGKAU + accumulator pattern
MULA
BINA jumlah: I64 = 0
BINA nombor: I64 = 1
BINA cacah: I64 = 0

SELAGI nombor <= 100 MAKA
MULA
    JIKA nombor > 10 MAKA
    MULA
        HENTI
    TAMAT
    BINA jumlah = jumlah + nombor
    BINA nombor = nombor + 1
    BINA cacah = cacah + 1
TAMAT

PAPAR jumlah

BINA gandaan: I64 = 0
BINA terkini: I64 = 3

SELAGI terkini <= 30 MAKA
MULA
    BINA gandaan = gandaan + terkini
    BINA terkini = terkini + 3
TAMAT

PAPAR gandaan

ULANG MULA
    JIKA cacah == 0 MAKA
    MULA
        HENTI
    TAMAT
    BINA cacah = cacah - 1
TAMAT

PAPAR cacah
TAMAT
