{
    fn tambah_reflex(input: I64, bias: I64) -> I64 {
        let total: I64 = input + bias;
        return total;
    }

    FUNGSI skala_reflex(nilai: I64, gandaan: I64) -> I64 MULA
        BINA hasil: I64 = nilai * gandaan
        PULANG hasil
    TAMAT

    let baseline: I64 = 8;
    let bias: I64 = 3;
    let sample_score: I64 = baseline + bias;
    print sample_score;
}
